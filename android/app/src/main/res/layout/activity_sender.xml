<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/abyss">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PAYLOAD SENDER"
            android:textColor="@color/amber"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:textSize="20sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stream an .elf payload to your PS5 over TCP (default port 9021)"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btn_pick"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CHOOSE .ELF FILE"
            android:fontFamily="monospace"
            android:backgroundTint="@color/ps_blue" />

        <TextView
            android:id="@+id/tv_file"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No file selected"
            android:textColor="@color/text_dim"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TARGET IP"
            android:textColor="@color/amber"
            android:fontFamily="monospace"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/et_ip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="192.168.1.10"
            android:fontFamily="monospace"
            android:inputType="text|textUri"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PORT"
            android:textColor="@color/amber"
            android:fontFamily="monospace"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/et_port"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="9021"
            android:fontFamily="monospace"
            android:inputType="number"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btn_send"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="SEND"
            android:textStyle="bold"
            android:textSize="18sp"
            android:fontFamily="monospace"
            android:backgroundTint="@color/amber"
            android:textColor="@color/abyss" />

        <ProgressBar
            android:id="@+id/send_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:max="1000"
            android:progressTint="@color/ps_blue" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HISTORY"
            android:textColor="@color/amber"
            android:fontFamily="monospace"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tv_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No payloads sent yet"
            android:textColor="@color/text_dim"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>
</ScrollView>
