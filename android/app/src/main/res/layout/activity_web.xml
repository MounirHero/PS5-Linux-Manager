<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/abyss">

    <WebView
        android:id="@+id/web"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ProgressBar
        android:id="@+id/progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="top"
        android:max="100"
        android:progressTint="@color/amber"
        android:progressBackgroundTint="@android:color/transparent" />

    <LinearLayout
        android:id="@+id/error_view"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/abyss"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONNECTION FAILED"
            android:textColor="@color/amber"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/error_url"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/ps_blue"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:layout_marginTop="14dp" />

        <TextView
            android:id="@+id/error_detail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/text_dim"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btn_retry"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="RETRY"
            android:fontFamily="monospace"
            android:backgroundTint="@color/ps_blue" />

        <Button
            android:id="@+id/btn_edit_conn"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="EDIT CONNECTION"
            android:fontFamily="monospace"
            android:backgroundTint="@color/amber"
            android:textColor="@color/abyss" />
    </LinearLayout>
</FrameLayout>
